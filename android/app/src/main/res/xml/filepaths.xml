<?xml version="1.0" encoding="utf-8"?>
<!--
  Paths the in-app updater's FileProvider (${applicationId}.fileProvider) is
  allowed to expose to the system package installer. The updater writes the
  downloaded APK to the app-specific external files directory
  (getExternalStorageDirectory()), which maps to <external-files-path>.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <external-files-path name="external_files" path="." />
    <external-cache-path name="external_cache" path="." />
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
</paths>
